# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage
SUPABASE_STORAGE_BUCKET=ovn-nexus-datasets

# Music Studio — Storage bucket for audio uploads
SUPABASE_MUSIC_BUCKET=music-uploads

# ML Pipeline (optional)
ML_API_ENDPOINT=https://your-ml-endpoint.run.app
ML_API_KEY=your-ml-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ElevenLabs Voice IDs
ELEVENLABS_VOICE_ID_ERYN=your-eryn-voice-id
ELEVENLABS_VOICE_ID_PETER=your-peter-voice-id

# ElevenLabs Voice Agent
ELEVENLABS_AGENT_ID=your-agent-id

# ElevenLabs Text to Dialogue (Eleven v3 model)
# Used for generating multi-speaker clinical scenario audio
ELEVENLABS_TEXT_TO_DIALOGUE_MODEL=eleven_v3
